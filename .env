# ----------------------------------------------------
# 域名配置
# ----------------------------------------------------
# 前端应用访问地址
APP_URL=https://ai.wyoooni.net
VITE_APP_URL=https://ai.wyoooni.net

# 后端API地址（nginx反代8012端口）
# 方案2: 使用同域名+路径转发，前端使用相对路径 /api
API_URL=
VITE_API_URL=

# 图片素材基础URL
IMAGE_BASE_URL=https://lobe.wyoooni.net
VITE_IMAGE_BASE_URL=https://lobe.wyoooni.net

# ----------------------------------------------------
# 后端服务配置
# ----------------------------------------------------
# API服务端口（nginx会转发到此端口）
API_PORT=8012

